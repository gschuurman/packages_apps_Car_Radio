<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingStart="@dimen/ui_content_pad"
    android:paddingEnd="@dimen/ui_content_pad"
    android:paddingTop="26dp"
    android:paddingBottom="26dp">

    <!-- LEFT: art + presets -->
    <LinearLayout
        android:layout_width="@dimen/ui_now_art"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/now_art_tile"
            android:layout_width="@dimen/ui_now_art"
            android:layout_height="@dimen/ui_now_art">

            <ImageView
                android:id="@+id/now_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/now_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="104dp"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="#A0000000">

                <View
                    android:id="@+id/now_live_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="7dp"
                    android:background="@color/ui_live" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_live"
                    android:textColor="@color/ui_text"
                    android:textSize="@dimen/ui_text_xs"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="9dp"
            android:text="@string/label_presets"
            android:textColor="@color/ui_text_faint"
            android:textSize="@dimen/ui_text_xs"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.14" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <include android:id="@+id/preset_0" layout="@layout/preset_button"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" />
            <Space android:layout_width="9dp" android:layout_height="0dp" />
            <include android:id="@+id/preset_1" layout="@layout/preset_button"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:orientation="horizontal">
            <include android:id="@+id/preset_2" layout="@layout/preset_button"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" />
            <Space android:layout_width="9dp" android:layout_height="0dp" />
            <include android:id="@+id/preset_3" layout="@layout/preset_button"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:orientation="horizontal">
            <include android:id="@+id/preset_4" layout="@layout/preset_button"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" />
            <Space android:layout_width="9dp" android:layout_height="0dp" />
            <include android:id="@+id/preset_5" layout="@layout/preset_button"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- RIGHT: metadata + transport -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="34dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/now_band"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:textSize="@dimen/ui_text_xs"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/now_sub"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="13dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="@color/ui_text_dim"
                android:textSize="@dimen/ui_text_sm" />

            <com.android.car.radio.widget.SignalMeter
                android:id="@+id/now_signal"
                android:layout_width="44dp"
                android:layout_height="@dimen/ui_signal_h" />
        </LinearLayout>

        <!-- transient status: "Tuning…" while acquiring, "No signal" when a band won't lock -->
        <LinearLayout
            android:id="@+id/now_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/now_status_spinner"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/now_status_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="@color/ui_text_dim"
                android:textSize="@dimen/ui_text_md" />
        </LinearLayout>

        <TextView
            android:id="@+id/now_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/ui_text"
            android:textSize="@dimen/ui_text_name"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/now_genre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="@color/ui_text_dimmer"
            android:textSize="@dimen/ui_text_md" />

        <!-- DLS card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:background="@drawable/bg_card">

            <com.android.car.radio.widget.EqualizerView
                android:id="@+id/now_eq"
                android:layout_width="22dp"
                android:layout_height="22dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_now_playing_dls"
                    android:textColor="@color/ui_text_faint"
                    android:textSize="@dimen/ui_text_xs"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/now_dls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textColor="@color/ui_text"
                    android:textSize="@dimen/ui_text_md" />
            </LinearLayout>
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- transport -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/now_prev"
                android:layout_width="@dimen/ui_transport"
                android:layout_height="@dimen/ui_transport"
                android:padding="20dp"
                android:src="@drawable/ic_skip_previous"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/now_play"
                android:layout_width="@dimen/ui_transport_main"
                android:layout_height="@dimen/ui_transport_main"
                android:layout_marginStart="14dp"
                android:padding="26dp"
                android:src="@drawable/ic_pause"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/now_next"
                android:layout_width="@dimen/ui_transport"
                android:layout_height="@dimen/ui_transport"
                android:layout_marginStart="14dp"
                android:padding="20dp"
                android:src="@drawable/ic_skip_next"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:layout_width="1dp"
                android:layout_height="42dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@color/ui_border" />

            <ImageView
                android:id="@+id/now_fav"
                android:layout_width="@dimen/ui_transport"
                android:layout_height="@dimen/ui_transport"
                android:padding="20dp"
                android:src="@drawable/ic_star_empty"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/now_scan"
                android:layout_width="wrap_content"
                android:layout_height="62dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/now_scan_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="9dp"
                    android:src="@drawable/ic_scan" />

                <TextView
                    android:id="@+id/now_scan_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_scan"
                    android:textSize="@dimen/ui_text_md"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
