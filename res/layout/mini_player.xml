<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/ui_mini_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/ui_rail"
    android:paddingStart="16dp"
    android:paddingEnd="20dp">

    <LinearLayout
        android:id="@+id/mini_expand"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">

        <TextView
            android:id="@+id/mini_logo"
            android:layout_width="@dimen/ui_logo"
            android:layout_height="@dimen/ui_logo"
            android:gravity="center"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/ui_text_md"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="15dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/mini_band"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="10dp"
                    android:textSize="@dimen/ui_text_xs"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/mini_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textColor="@color/ui_text"
                    android:textSize="@dimen/ui_text_md"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/mini_dls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="@color/ui_text_dimmer"
                android:textSize="@dimen/ui_text_sm" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/mini_prev"
        android:layout_width="@dimen/ui_transport"
        android:layout_height="@dimen/ui_transport"
        android:layout_marginStart="10dp"
        android:padding="20dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_skip_previous"
        android:background="?android:attr/selectableItemBackgroundBorderless" />

    <ImageView
        android:id="@+id/mini_play"
        android:layout_width="@dimen/ui_transport"
        android:layout_height="@dimen/ui_transport"
        android:layout_marginStart="6dp"
        android:padding="22dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_pause"
        android:background="?android:attr/selectableItemBackgroundBorderless" />

    <ImageView
        android:id="@+id/mini_next"
        android:layout_width="@dimen/ui_transport"
        android:layout_height="@dimen/ui_transport"
        android:layout_marginStart="6dp"
        android:padding="20dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_skip_next"
        android:background="?android:attr/selectableItemBackgroundBorderless" />
</LinearLayout>
