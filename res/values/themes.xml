<resources>
    <!-- Theme for the app. The modernized UI draws its own shell (nav rail + top bar +
         mini player), so we use a plain dark no-action-bar theme instead of the CarUi
         toolbar theme. -->
    <style name="Theme.Radio" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/ui_bg</item>
        <item name="android:colorAccent">@color/ui_accent_dab</item>
        <item name="android:statusBarColor">@color/ui_rail</item>
        <item name="android:navigationBarColor">@color/ui_rail</item>
        <item name="textAppearanceGridItem">@android:style/TextAppearance.DeviceDefault.Medium</item>
        <item name="textAppearanceGridItemSecondary">@android:style/TextAppearance.DeviceDefault.Small</item>
    </style>
</resources>
