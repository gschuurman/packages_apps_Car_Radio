<resources>
    <!-- The default margins -->
    <dimen name="radio_margin">@dimen/car_ui_margin</dimen>
    <dimen name="control_button_size">@dimen/car_ui_touch_target_size</dimen>
    <dimen name="control_button_margin">@dimen/car_ui_padding_1</dimen>

    <!-- The top margin for the container that displays the current station and band. This value
         is negative in order to align the top of the channel text with the top of the metadata
         text. -->
    <dimen name="station_top_margin">-16dp</dimen>

    <!-- Inner padding for the radio buttons. This value creates a touch target on the buttons that
         is wider than the icon size. -->
    <dimen name="radio_controls_button_padding">16dp</dimen>

    <!-- Browse items -->
    <dimen name="browse_list_padding">@dimen/car_ui_padding_4</dimen>
    <dimen name="browse_item_height">96dp</dimen>
    <dimen name="browse_item_metadata_width">0dp</dimen>
    <dimen name="browse_item_spacing">@dimen/car_ui_padding_3</dimen>
    <!-- The dimensions of the pill background behind each favorite channel. -->
    <dimen name="browse_number_bg_width">158dp</dimen>
    <dimen name="browse_number_bg_height">56dp</dimen>
    <dimen name="browse_number_bg_radius">8dp</dimen>
    <!-- The space between the currently playing icon and the radio band -->
    <dimen name="browse_equalizer_padding">@dimen/car_ui_padding_1</dimen>
    <dimen name="browse_list_fading_edge_length">@dimen/car_ui_padding_4</dimen>

    <!-- Drawables -->
    <dimen name="ic_backspace_height">48dp</dimen>
    <dimen name="ic_backspace_width">48dp</dimen>
    <dimen name="ic_equalizer_height">36dp</dimen>
    <dimen name="ic_equalizer_width">36dp</dimen>
    <dimen name="ic_input_antenna_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_input_antenna_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_list_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_list_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_pause_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_pause_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_play_arrow_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_play_arrow_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_play_arrow_off_height">56dp</dimen>
    <dimen name="ic_play_arrow_off_width">56dp</dimen>
    <dimen name="ic_radio_am_height">34dp</dimen>
    <dimen name="ic_radio_am_width">34dp</dimen>
    <dimen name="ic_radio_fm_height">34dp</dimen>
    <dimen name="ic_radio_fm_width">34dp</dimen>
    <dimen name="ic_skip_next_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_skip_next_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_skip_previous_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_skip_previous_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_star_empty_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_star_empty_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_star_filled_height">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_star_filled_width">@dimen/car_ui_primary_icon_size</dimen>
    <dimen name="ic_manual_tuner_button_radius">6dp</dimen>
    <dimen name="ic_playback_card_background_radius">6dp</dimen>
    <dimen name="ic_playback_button_background_radius">6dp</dimen>

    <!-- Playback card -->
    <dimen name="playback_card_height">96dp</dimen>
    <dimen name="playback_card_controls_width">0dp</dimen>
    <dimen name="playback_card_controls_height">@dimen/playback_card_height</dimen>
    <dimen name="playback_card_art_size">@dimen/playback_card_height</dimen>
    <dimen name="playback_card_channel_size">@dimen/playback_card_height</dimen>
    <dimen name="playback_card_interior_padding">@dimen/car_ui_padding_4</dimen>
    <dimen name="playback_card_text_spacing">@dimen/car_ui_padding_1</dimen>
    <dimen name="playback_card_margin_horizontal">@dimen/car_ui_margin</dimen>
    <dimen name="playback_card_margin_bottom">@dimen/car_ui_padding_5</dimen>
    <dimen name="playback_card_station_name_width">0dp</dimen>
    <dimen name="playback_card_station_details_width">0dp</dimen>

    <!-- Radio Activity -->
    <dimen name="radio_activity_pager_size">0dp</dimen>
    <dimen name="radio_activity_status_size">0dp</dimen>
    <dimen name="radio_activity_playback_width">0dp</dimen>

    <!-- Tuner Buttons -->
    <dimen name="tune_button_width">254dp</dimen>
    <dimen name="tune_button_height">76dp</dimen>
    <dimen name="dialpad_space_horizontal">@dimen/car_ui_padding_5</dimen>
    <dimen name="dialpad_space_vertical">@dimen/car_ui_padding_5</dimen>
    <dimen name="dialpad_button_size">@dimen/control_button_size</dimen>
    <dimen name="dialpad_button_padding">0dp</dimen>

    <!-- Tab/App bar dimensions -->
    <dimen name="tab_height">@dimen/car_ui_toolbar_row_height</dimen>
    <dimen name="tab_icon_margin">@dimen/car_ui_padding_1</dimen>
    <dimen name="tab_elevation">8dp</dimen>
    <dimen name="tab_padding">@dimen/car_ui_padding_4</dimen>
    <dimen name="tab_margin_start">@dimen/car_ui_padding_4</dimen>
    <dimen name="tab_margin_end">@dimen/radio_margin</dimen>
    <dimen name="band_selector_size">@dimen/tab_height</dimen>

    <!-- ===== Modernized UI (AAOS Radio redesign) =====
         Device is 1024x600 at density 100, so 1dp = 0.625px (dp = px * 1.6).
         Values below are chosen in dp to render at sensible px sizes on that panel. -->
    <dimen name="ui_rail_width">150dp</dimen>
    <dimen name="ui_topbar_height">92dp</dimen>
    <dimen name="ui_mini_height">120dp</dimen>
    <dimen name="ui_content_pad">28dp</dimen>
    <dimen name="ui_radius">22dp</dimen>
    <dimen name="ui_radius_sm">14dp</dimen>
    <dimen name="ui_nav_icon">38dp</dimen>
    <dimen name="ui_nav_btn">112dp</dimen>
    <dimen name="ui_now_art">320dp</dimen>
    <dimen name="ui_logo">68dp</dimen>
    <dimen name="ui_logo_sm">40dp</dimen>
    <dimen name="ui_transport">96dp</dimen>
    <dimen name="ui_transport_main">120dp</dimen>
    <dimen name="ui_signal_bar_w">5dp</dimen>
    <dimen name="ui_signal_gap">4dp</dimen>
    <dimen name="ui_signal_h">34dp</dimen>
    <dimen name="ui_text_title">36dp</dimen>
    <dimen name="ui_text_name">74dp</dimen>
    <dimen name="ui_text_lg">26dp</dimen>
    <dimen name="ui_text_md">22dp</dimen>
    <dimen name="ui_text_sm">19dp</dimen>
    <dimen name="ui_text_xs">17dp</dimen>

    <!-- Band tab touch targets. Panel density is 100 (px = dp * 0.625), so the old
         22dp/9dp padding rendered as a ~59x29 px target that was hard to hit. -->
    <dimen name="ui_band_tab_minw">132dp</dimen>
    <dimen name="ui_band_tab_minh">78dp</dimen>
    <dimen name="ui_band_tab_padh">34dp</dimen>
    <dimen name="ui_band_tab_padv">22dp</dimen>

</resources>
